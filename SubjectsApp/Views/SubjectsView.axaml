<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SubjectsApp.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SubjectsApp.Views.SubjectsView"
             x:DataType="vm:SubjectsViewModel"
             x:Name="Control">
    <Grid RowDefinitions="Auto,*">
        <Expander Grid.Row="0" Header="Текущие предметы" IsExpanded="True" Margin="0,4">
            <ItemsControl ItemsSource="{Binding StudentSubjects}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <TextBlock Text="{Binding}" Margin="2"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Expander>

        <Expander Grid.Row="1" Header="Доступные предметы" IsExpanded="True">
            <ItemsControl ItemsSource="{Binding AvailableSubjects}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="2">
                            <TextBlock Text="{Binding}" VerticalAlignment="Center" MinWidth="120"/>
                            <Button Content="Добавить"
                                    Command="{Binding ViewModel.AddSubjectCommand, ElementName=Control}"
                                    CommandParameter="{Binding}"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Expander>
    </Grid>
</UserControl>