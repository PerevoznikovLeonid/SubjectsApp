<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SubjectsApp.ViewModels"
             xmlns:m="using:SubjectsApp.Models"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SubjectsApp.Views.StudentsView"
             x:DataType="vm:StudentsViewModel"
             x:Name="Control">
    <Grid ColumnDefinitions="220,*" Margin="8">
        <ListBox Grid.Column="0" ItemsSource="{Binding Students}"
                 SelectedItem="{Binding SelectedStudent, Mode=TwoWay}"
                 Margin="4">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="m:Student">
                    <TextBlock Text="{Binding FullName}" Margin="6,4"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        
        <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*" Margin="12,4,4,4">
            <TextBlock Grid.Row="0" FontSize="20" FontWeight="Bold" Margin="0,0,0,8"
                       Text="{Binding SelectedStudent.FullName, FallbackValue='Выберите студента'}"/>
            
            <Expander Grid.Row="1" Header="Текущие предметы" IsExpanded="True" Margin="0,4">
                <ItemsControl ItemsSource="{Binding StudentSubjects}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="4,2">
                                <TextBlock Text="{Binding}" VerticalAlignment="Center" MinWidth="120"/>
                                <Button Content="Удалить"
                                        Command="{Binding ViewModel.RemoveSubjectCommand, ElementName=Control}"
                                        CommandParameter="{Binding}"
                                        Classes="danger"
                                        Margin="4,0,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Expander>
            
            <Expander Grid.Row="2" Header="Добавить предмет" IsExpanded="True" Margin="0,8,0,0">
                <ItemsControl ItemsSource="{Binding AvailableSubjects}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="4,2">
                                <TextBlock Text="{Binding}" VerticalAlignment="Center" MinWidth="120"/>
                                <Button Content="Добавить"
                                        Command="{Binding ViewModel.AddSubjectCommand, ElementName=Control}"
                                        CommandParameter="{Binding}"
                                        Margin="4,0,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Expander>
        </Grid>
    </Grid>
</UserControl>
